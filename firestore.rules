rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get user profile
    function getUserProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }
    
    // Helper function to check if user is admin (dean email)
    function isAdmin() {
      let profile = getUserProfile();
      return profile.email == 'abhigyankumar268@gmail.com';
    }
    
    // Helper function to check if user is teacher
    function isTeacher() {
      let profile = getUserProfile();
      return profile.role == 'teacher';
    }
    
    // ==================== PROFILES ====================
    match /profiles/{profileId} {
      // Anyone can read profiles (for displaying student/teacher lists)
      allow read: if true;
      
      // Users can create their own profile during onboarding
      allow create: if isAuthenticated() && 
                     request.auth.uid == request.resource.data.clerk_user_id;
      
      // Users can update their own profile, admins can update anyone
      allow update: if isAuthenticated() && 
                    (request.auth.uid == resource.data.clerk_user_id || isAdmin());
      
      // Only admins can delete profiles
      allow delete: if isAdmin();
    }
    
    // ==================== COURSES ====================
    match /courses/{courseId} {
      // Anyone can read published courses
      allow read: if true;
      
      // Teachers can create courses
      allow create: if isAuthenticated() && isTeacher();
      
      // Teachers can update their own courses, admins can update any
      allow update: if isAuthenticated() && 
                    (resource.data.teacher_id == getUserProfile().id || isAdmin());
      
      // Teachers can delete their own courses, admins can delete any
      allow delete: if isAuthenticated() && 
                    (resource.data.teacher_id == getUserProfile().id || isAdmin());
    }
    
    // ==================== CHAPTERS ====================
    match /chapters/{chapterId} {
      // Anyone can read chapters (for course viewing)
      allow read: if true;
      
      // Teachers can create chapters
      allow create: if isAuthenticated() && isTeacher();
      
      // Teachers can update chapters they own
      allow update: if isAuthenticated() && isTeacher();
      
      // Teachers can delete chapters
      allow delete: if isAuthenticated() && isTeacher();
    }
    
    // ==================== ENROLLMENTS ====================
    match /enrollments/{enrollmentId} {
      // Authenticated users can read enrollments
      allow read: if isAuthenticated();
      
      // Students can enroll themselves
      allow create: if isAuthenticated() && 
                    request.auth.uid == request.resource.data.student_id;
      
      // Students can update their own enrollments (mark as complete)
      allow update: if isAuthenticated() && 
                    request.auth.uid == resource.data.student_id;
      
      // Admins and teachers can delete enrollments
      allow delete: if isAdmin() || isTeacher();
    }
    
    // ==================== QUIZZES ====================
    match /quizzes/{quizId} {
      // Students can read quizzes
      allow read: if isAuthenticated();
      
      // Teachers can create quizzes
      allow create: if isAuthenticated() && isTeacher();
      
      // Teachers can update their quizzes
      allow update: if isAuthenticated() && isTeacher();
      
      // Teachers can delete quizzes
      allow delete: if isAuthenticated() && isTeacher();
    }
    
    // ==================== QUIZ ATTEMPTS ====================
    match /quiz_attempts/{attemptId} {
      // Users can read their own attempts, teachers can read all
      allow read: if isAuthenticated() && 
                  (request.auth.uid == resource.data.user_id || isTeacher());
      
      // Students can create their own attempts
      allow create: if isAuthenticated() && 
                    request.auth.uid == request.resource.data.user_id;
      
      // No updates allowed (quiz attempts are immutable)
      allow update: if false;
      
      // No deletes (keep history)
      allow delete: if false;
    }
    
    // ==================== DISCUSSIONS ====================
    match /discussions/{discussionId} {
      // Anyone can read discussions (for learning)
      allow read: if true;
      
      // Authenticated users can create discussions
      allow create: if isAuthenticated();
      
      // Users can delete their own discussions, admins can delete any
      allow delete: if isAuthenticated() && 
                    (request.auth.uid == resource.data.user_id || isAdmin());
    }
    
    // ==================== UTILITY COLLECTIONS ====================
    
    // Any other collection not specified above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
